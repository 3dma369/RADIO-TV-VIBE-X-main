rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // VIBE_X CHAT — public read, authenticated write with message validation
    match /vibe_x_chat/{messageId} {
      allow read: if true;
      allow create: if request.auth != null
                  && request.resource.data.message is string
                  && request.resource.data.message.size() > 0
                  && request.resource.data.message.size() < 500;
    }

    // PLAYLISTS — public read, authenticated write only
    match /vibe_x_playlist/{trackId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PRODUCTS — public read, authenticated write only (admin)
    match /vibe_x_products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // DJs — public read, authenticated write only
    match /vibe_x_djs/{djId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // SCHEDULE — public read, authenticated write only
    match /vibe_x_schedule/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // LISTENERS — auth required (tracking who is listening)
    match /vibe_x_listeners/{listenerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // USER PROFILES — users can only access their own profile
    match /vibe_x_profiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ANALYTICS — public read, auth write for tracking
    match /listenerHistory/{recordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sessionHistory/{recordId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /pageViews/{recordId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // TRACKS — public read, authenticated uploads only
    match /tracks/{trackId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}