rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ───────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // VIBE_X CHAT — public read, authenticated write with message validation
    match /vibe_x_chat/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated()
                  && request.resource.data.message is string
                  && request.resource.data.message.size() > 0
                  && request.resource.data.message.size() < 500;
      allow update, delete: if isAdmin();
    }

    // PLAYLISTS — public read, admin write
    match /vibe_x_playlist/{trackId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PRODUCTS — public read, admin write
    match /vibe_x_products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DJs — public read, admin write
    match /vibe_x_djs/{djId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SCHEDULE — public read, admin write
    match /vibe_x_schedule/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // LISTENERS — auth required (tracking who is listening), owner only
    match /vibe_x_listeners/{listenerId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == listenerId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == listenerId;
      allow delete: if isAdmin();
    }

    // USER PROFILES — users can only access their own profile
    match /vibe_x_profiles/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ANALYTICS — admin read only (these are your business metrics)
    match /listenerHistory/{recordId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /sessionHistory/{recordId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /pageViews/{recordId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // PAYMENTS — owner or admin only. SECURITY FIX: was public read, which
    // exposed all transaction metadata to anyone on the internet.
    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // TRACKS — public read, admin upload
    match /tracks/{trackId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Catch-all: deny by default, admin escape hatch
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}