rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public assets (music, images, products) - READ ONLY for everyone
    match /public/{allPaths=**} {
      allow read: if true;
      // Only authenticated users can upload to public
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    // Music library — public read, admin-only write
    // JUNGLE-DNB and other moods read pre-signed URLs from Firestore; we make
    // the files publicly readable so the signed URLs aren't gated by auth.
    match /music_mp3/{allPaths=**} {
      allow read: if true;
      allow write: if false; // uploads via Admin SDK only
    }

    // User uploads (avatars, profile pics) - auth required
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // Public read so others can see profiles
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // Admin-only paths (backups, config, system files)
    match /admin/{allPaths=**} {
      allow read, write: if false; // Use Admin SDK only, never client
    }

    // Default deny - all other paths require explicit auth
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
